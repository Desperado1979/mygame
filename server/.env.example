# Copy to .env and load with your process manager, or export in shell before npm run persist.
# PORT=8787

# P3-2 — optional rejection / alert (default: all off)
# REJECT_HIGH_WARNINGS=1
# REJECT_SRVVAL_AUDIT=1
# SRVVAL_REJECT_CATEGORIES=SrvVal_IllegalOperation,SrvVal_CombatMiss
# SRVVAL_REJECT_THRESHOLD_JSON={"SrvVal_IllegalOperation":1}
# SRVVAL_ALERT_THRESHOLD_JSON={"SrvVal_IllegalOperation":5}

# D6 — maintenance / limits / idempotency / HMAC / staging (default: off)
# MAINTENANCE_MODE=1
# SYNC_RATE_LIMIT_PER_MINUTE=30
# SYNC_IDEMPOTENCY_TTL_MS=300000
# D12 — persist Idempotency-Key 200 cache to data/idempotency-cache.json (requires TTL>0; single instance)
# SYNC_IDEMPOTENCY_PERSIST=1
# SYNC_HMAC_SECRET=change_me
# SYNC_REQUIRE_STAGING_HEADER=1
# D9 — issuedAtUtc skew vs server clock (seconds; 0 = off)
# SYNC_ISSUED_AT_MAX_SKEW_SEC=600

# D10 — compliance hints (informational; not enforced by persist_sync)
# COMPLIANCE_METRICS_RETENTION_HINT_DAYS=90
# COMPLIANCE_PLAYER_STATE_RETENTION_HINT_DAYS=365
# AUDIT_EXPORT_BUCKET_PREFIX=my-game-audit-dev

# D15 — PATCH state write rehearsal (loads existing save, merges ops into state, re-validates)
# REHEARSAL_PATCH_WRITE=1

# D16 — ETag / If-Match optimistic concurrency (default: If-Match validated when sent)
# SYNC_ETAG_DISABLED=1

# D14 — audit replay tail vs state: warnings become 400 when mismatched (staging gate)
# SYNC_AUDIT_STATE_STRICT=1

# D13 — PATCH rehearsal: POST /rehearsal/validate-patch (no env required; see README D13)
# D11 — map validation warning codes → SrvVal_* hint counts (auditSummary.srvValFromWarnings; observation only)
# SYNC_WARNING_SRVVAL_BRIDGE=1
# WARNING_CODE_TO_SRVVAL_JSON={"gold_tail_mismatch":"SrvVal_WalletReject"}

# Logging
# LOG_AUDIT_SUMMARY=1
# LOG_REDACT_PII=1
