{
  "name": "server",
  "version": "1.0.0",
  "description": "D5 persist_sync + validation tools (D16 ETag/If-Match; rehearsal PATCH; metrics).",
  "main": "index.js",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "persist": "node tools/persist_sync.cjs",
    "validate": "node tools/validate_sync_file.cjs",
    "compare-state": "node tools/compare_state_export.cjs",
    "health-check": "node tools/health_check.cjs",
    "metrics-csv": "node tools/metrics_export_csv.cjs",
    "daily-risk": "node tools/daily_risk_report.cjs",
    "risk-players": "node tools/risk_players_report.cjs",
    "risk-codes": "node tools/risk_codes_report.cjs",
    "risk-rejections": "node tools/risk_rejections_report.cjs",
    "anomaly-report": "node tools/anomaly_report.cjs",
    "risk-brief": "node tools/risk_brief.cjs",
    "risk-alerts": "node tools/risk_alerts.cjs",
    "risk-player-alerts": "node tools/risk_player_alerts.cjs",
    "daily-risk-template": "node tools/daily_risk_template.cjs",
    "daily-risk-index": "node tools/daily_risk_archive_index.cjs",
    "risk-dashboard": "node tools/risk_dashboard.cjs",
    "risk-doctor": "node tools/risk_doctor.cjs",
    "risk-smoke": "node tools/risk_smoke.cjs",
    "risk-doctor-serial": "node tools/risk_doctor.cjs --parallel 0 --retries 1",
    "risk-smoke-report": "node tools/risk_smoke.cjs --jsonOut data/risk_smoke.json --markdownOut data/risk_smoke.md",
    "risk-smoke-trend": "node tools/risk_smoke.cjs --jsonOut data/risk_smoke_now.json --compareWith data/risk_smoke_baseline.json --saveAsBaseline data/risk_smoke_baseline.json --historyOut data/risk_smoke_history.ndjson",
    "risk-smoke-gate": "node tools/risk_smoke.cjs --jsonOut data/risk_smoke_gate.json --markdownOut data/risk_smoke_gate.md --maxFailed 0 --requireOk 1",
    "risk-doctor-core": "node tools/risk_doctor.cjs --only health,metrics_report,dashboard",
    "risk-smoke-history": "node tools/risk_smoke_history_report.cjs --days 7,30 --jsonOut data/risk_smoke_history_report.json",
    "test": "echo \"Error: no test specified\" && exit 1",
    "metrics-report": "node tools/metrics_report.cjs",
    "audit-categories": "node tools/fetch_audit_categories.cjs",
    "metrics-prometheus": "node tools/fetch_prometheus_metrics.cjs",
    "merge-metrics-ndjson": "node tools/merge_metrics_ndjson.cjs",
    "audit-replay": "node tools/audit_replay_cli.cjs",
    "sync-summary": "node tools/fetch_sync_summary.cjs",
    "check-schema-version": "node tools/check_schema_version_constants.cjs",
    "check-schema-snapshot": "node tools/check_schema_files_snapshot.cjs",
    "audit-export-bundle": "node tools/audit_export_bundle.cjs",
    "check-locale-ci": "node tools/check_locale_placeholder.cjs",
    "metrics-archive": "node tools/metrics_archive_lines.cjs",
    "validate-patch-rehearsal": "node tools/patch_validate_rehearsal.cjs --smoke",
    "check-syntax": "node --check tools/persist_sync.cjs && node --check tools/audit_validate.cjs && node --check tools/schema_validate.cjs && node --check tools/patch_validate_rehearsal.cjs && node --check tools/health_check.cjs && node --check tools/validate_sync_file.cjs && node --check tools/compare_state_export.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
